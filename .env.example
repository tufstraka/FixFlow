# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://fixflow:fixflow_password@localhost:5432/fixflow

# GitHub App Configuration
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_here
-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# MNEE Configuration
# Get API key from https://developer.mnee.net/
MNEE_API_KEY=your_mnee_api_key
MNEE_ENVIRONMENT=sandbox
MNEE_WALLET_WIF=your_wallet_wif
MNEE_WEBHOOK_SECRET=optional_webhook_secret

# API Security
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update('your-api-key').digest('hex'))"
API_KEY_HASH=sha256_hash_of_your_api_key

# Logging
LOG_LEVEL=info